# ===== Hide Island configuration =====
# Copy to ".env" and fill in to enable the real wallet. Without these the game
# runs in MOCK wallet mode (fully playable, no real funds).

PORT=3000

# Wallet mode: "mock" (default) or "privy"
WALLET_MODE=mock

# --- Privy (embedded wallets + login with X) ---
# Create an app at https://dashboard.privy.io
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- Solana ---
# An RPC endpoint (mainnet-beta, devnet, or a provider like Helius/QuickNode).
SOLANA_RPC_URL=https://api.devnet.solana.com

# Your pump.fun / bags.app deployed token mint address.
GAME_TOKEN_MINT=
